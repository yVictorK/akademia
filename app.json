{
  "expo": {
    "name": "akademia",
    "slug": "akademia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#241D26"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akademia"
    },
    "android": {
      "compileSdk": "33",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#241d24"
      },
      "package": "com.akademia"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/Nexa/Nexa-Heavy.ttf",
            "./src/assets/fonts/Poppins/Poppins-Medium.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "98636026-a453-4b3f-8437-1f2ac785e1a9"
      }
    },
    "owner": "yvictork22"
  }
}